---
layout: null
---
{% assign author = site.author %}
{
  "version": "https://jsonfeed.org/version/1.1",
  "title": {{ site.title | jsonify }},
  "home_page_url": {{ "/" | absolute_url | jsonify }},
  "feed_url": {{ "/feed.json" | absolute_url | jsonify }},
  "description": {{ site.description | jsonify }},
  "icon": {{ "/apple-touch-icon.png" | absolute_url | jsonify }},
  "favicon": {{ "/favicon.png" | absolute_url | jsonify }},
  "authors": [
    {
      "name": {{ author.name | jsonify }},
      "url": {{ author.url | jsonify }},
      "avatar": {{ author.avatar | absolute_url | jsonify }}
    }
  ],
  "items": [
    {% for post in site.posts limit:36 %}
    {
      "id": {{ post.url | absolute_url | jsonify }},
      "url": {{ post.url | absolute_url | jsonify }},
      "title": {{ post.title | jsonify }},
      "summary": {{ post.description | default: post.summary | jsonify }},
      "content_html": {{ post.content | strip_newlines | jsonify }},
      "date_published": {{ post.date | date_to_xmlschema | jsonify }},
      "date_modified": {{ post.date | date_to_xmlschema | jsonify }},
      {% if post.tags and post.tags != empty %}
      "tags": {{ post.tags | jsonify }},
      {% endif %}
      "authors": [
        {
          "name": {{ author.name | jsonify }},
          "url": {{ author.url | jsonify }},
          "avatar": {{ author.avatar | absolute_url | jsonify }}
        }
      ]
    }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ]
}
